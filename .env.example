# Copy this file to web/.env.local and studio/.env, then fill in your values.
# NEVER commit the actual .env files — they are in .gitignore.

# ── Sanity (required) ─────────────────────────────────────────────────────────
# Find these at https://sanity.io/manage → your project → API

NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
NEXT_PUBLIC_SANITY_DATASET=production

# Write token — only needed to run seed scripts locally, never needed by the frontend
SANITY_WRITE_TOKEN=your_write_token_here
